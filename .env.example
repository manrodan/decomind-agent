# Copia este archivo a .env y rellena con tus valores reales.
# .env está en .gitignore — nunca se sube.

# GCP project
GOOGLE_CLOUD_PROJECT=decomind-agent-challenge
GOOGLE_CLOUD_LOCATION=europe-west1

# Vertex AI (true cuando usamos ADC + Vertex, false si usaras AI Studio API key)
GOOGLE_GENAI_USE_VERTEXAI=true

# Modelo orquestador del agente
AGENT_MODEL=gemini-2.5-flash
